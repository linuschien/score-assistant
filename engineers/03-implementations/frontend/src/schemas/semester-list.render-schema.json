{
  "root": "semester-list-page",
  "elements": {
    "home-link": {
      "type": "Button",
      "props": {
        "id": "home-link",
        "label": "首頁",
        "variant": null,
        "disabled": null
      },
      "children": [],
      "on": {
        "press": [
          {
            "action": "navigate",
            "params": {
              "to": "home-page"
            }
          }
        ]
      }
    },
    "current-page-crumb": {
      "type": "Button",
      "props": {
        "id": "current-page-crumb",
        "label": "學期列表",
        "variant": null,
        "disabled": null
      },
      "children": [],
      "on": {
        "press": [
          {
            "action": "navigate",
            "params": {
              "to": "semester-list-page"
            }
          }
        ]
      }
    },
    "page-breadcrumb": {
      "type": "Breadcrumb",
      "props": {
        "id": "page-breadcrumb",
        "variant": "breadcrumb"
      },
      "children": [
        "home-link",
        "current-page-crumb"
      ]
    },
    "page-title": {
      "type": "Heading",
      "props": {
        "id": "page-title",
        "label": "學期列表",
        "text": "學期列表",
        "level": "h1"
      },
      "children": []
    },
    "create-semester-button": {
      "type": "Button",
      "props": {
        "id": "create-semester-button",
        "label": "建立學期",
        "variant": "primary",
        "disabled": null
      },
      "children": [],
      "on": {
        "press": [
          {
            "action": "executeBehavior",
            "params": {
              "ref": "Open Semester Form Modal for Create"
            }
          }
        ]
      }
    },
    "header-section": {
      "type": "div",
      "props": {
        "id": "header-section",
        "variant": "summary-section"
      },
      "children": [
        "page-title",
        "create-semester-button"
      ]
    },
    "view-classes-trigger": {
      "type": "Button",
      "props": {
        "id": "view-classes-trigger",
        "label": "查看班級",
        "variant": "primary",
        "disabled": null
      },
      "children": [],
      "on": {
        "press": [
          {
            "action": "navigate",
            "params": {
              "to": "class-list-page"
            }
          }
        ]
      }
    },
    "edit-semester-trigger": {
      "type": "Button",
      "props": {
        "id": "edit-semester-trigger",
        "label": "編輯",
        "variant": "secondary",
        "disabled": null
      },
      "children": [],
      "on": {
        "press": [
          {
            "action": "openModal",
            "params": {
              "id": "semester-form-modal"
            }
          }
        ]
      }
    },
    "delete-semester-trigger": {
      "type": "Button",
      "props": {
        "id": "delete-semester-trigger",
        "label": "刪除",
        "variant": "danger",
        "disabled": null
      },
      "children": [],
      "on": {
        "press": [
          {
            "action": "openModal",
            "params": {
              "id": "delete-semester-confirm-dialog"
            }
          }
        ]
      }
    },
    "semester-table": {
      "type": "DataTable",
      "props": {
        "id": "semester-table",
        "label": "學期資料表",
        "dataRef": "listSemesters",
        "columns": [
          {
            "field": "name",
            "label": "學期名稱",
            "sortable": true,
            "default_sort": "asc"
          },
          {
            "field": "startDate",
            "label": "起始日期",
            "sortable": true
          },
          {
            "field": "endDate",
            "label": "結束日期",
            "sortable": true
          },
          {
            "field": "classCount",
            "label": "班級數量"
          }
        ],
        "data": {
          "$bindState": "/data/listSemesters"
        }
      },
      "children": [
        "view-classes-trigger",
        "edit-semester-trigger",
        "delete-semester-trigger"
      ]
    },
    "list-section": {
      "type": "div",
      "props": {
        "id": "list-section",
        "variant": "list-section"
      },
      "children": [
        "semester-table"
      ]
    },
    "modal-semester-name-field": {
      "type": "Input",
      "props": {
        "id": "modal-semester-name-field",
        "label": "學期名稱",
        "name": "modal-semester-name-field",
        "type": "text",
        "placeholder": "例：112-1 第一學期",
        "value": {
          "$bindState": "/form/modal-semester-name-field"
        },
        "checks": null,
        "validateOn": null
      },
      "children": []
    },
    "modal-start-date-field": {
      "type": "DatePicker",
      "props": {
        "id": "modal-start-date-field",
        "label": "起始日期",
        "name": "modal-start-date-field",
        "storePath": "/form/modal-start-date-field",
        "disabled": null
      },
      "children": []
    },
    "modal-end-date-field": {
      "type": "DatePicker",
      "props": {
        "id": "modal-end-date-field",
        "label": "結束日期",
        "name": "modal-end-date-field",
        "storePath": "/form/modal-end-date-field",
        "disabled": null
      },
      "children": []
    },
    "modal-submit-semester-trigger": {
      "type": "Button",
      "props": {
        "id": "modal-submit-semester-trigger",
        "label": "儲存",
        "variant": "primary",
        "disabled": null
      },
      "children": [],
      "on": {
        "press": [
          {
            "action": "executeBehavior",
            "params": {
              "ref": "Create a new Semester",
              "id": "modal-submit-semester-trigger"
            }
          }
        ]
      }
    },
    "semester-form-modal": {
      "type": "Dialog",
      "props": {
        "id": "semester-form-modal",
        "title": "建立 / 編輯學期",
        "description": null,
        "openPath": "/modals/semester-form-modal"
      },
      "children": [
        "modal-semester-name-field",
        "modal-start-date-field",
        "modal-end-date-field",
        "modal-submit-semester-trigger"
      ],
      "visible": {
        "$state": "/modals/semester-form-modal"
      }
    },
    "delete-semester-warning-text": {
      "type": "Text",
      "props": {
        "id": "delete-semester-warning-text",
        "label": "此學期底下的所有班級、學生與成績資料將一並永久刪除，此操作無法復原。",
        "text": "此學期底下的所有班級、學生與成績資料將一並永久刪除，此操作無法復原。",
        "variant": "muted"
      },
      "children": []
    },
    "delete-semester-keyword-input": {
      "type": "Input",
      "props": {
        "id": "delete-semester-keyword-input",
        "label": "請輸入學期名稱以確認刪除",
        "name": "delete-semester-keyword-input",
        "type": "text",
        "placeholder": "請輸入欲刪除的學期名稱以確認",
        "value": {
          "$bindState": "/form/delete-semester-keyword-input"
        },
        "checks": null,
        "validateOn": null
      },
      "children": [],
      "on": {
        "press": [
          {
            "action": "executeBehavior",
            "params": {
              "ref": "nielsen:error-prevention",
              "id": "delete-semester-keyword-input"
            }
          }
        ]
      }
    },
    "confirm-delete-semester-trigger": {
      "type": "Button",
      "props": {
        "id": "confirm-delete-semester-trigger",
        "label": "確認刪除",
        "variant": "danger",
        "disabled": null
      },
      "children": [],
      "on": {
        "press": [
          {
            "action": "executeBehavior",
            "params": {
              "ref": "Delete a Semester",
              "id": "confirm-delete-semester-trigger"
            }
          }
        ]
      }
    },
    "cancel-delete-semester-trigger": {
      "type": "Button",
      "props": {
        "id": "cancel-delete-semester-trigger",
        "label": "取消",
        "variant": "secondary",
        "disabled": null
      },
      "children": []
    },
    "delete-semester-confirm-dialog": {
      "type": "AlertDialog",
      "props": {
        "id": "delete-semester-confirm-dialog",
        "label": "確認刪除學期",
        "text": "確認刪除學期",
        "variant": "confirm-dialog"
      },
      "children": [
        "delete-semester-warning-text",
        "delete-semester-keyword-input",
        "confirm-delete-semester-trigger",
        "cancel-delete-semester-trigger"
      ],
      "visible": {
        "$state": "/modals/delete-semester-confirm-dialog"
      }
    },
    "semester-list-page": {
      "type": "Container:page",
      "props": {
        "id": "semester-list-page",
        "variant": "page"
      },
      "children": [
        "page-breadcrumb",
        "header-section",
        "list-section",
        "semester-form-modal",
        "delete-semester-confirm-dialog"
      ]
    }
  }
}