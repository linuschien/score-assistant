{
  "ui_id": "student-list",
  "domain_module": "CoreDomain",
  "root_element": {
    "id": "student-list-page",
    "abstract_type": "Container",
    "semantic_variant": "page",
    "children": [
      {
        "id": "page-breadcrumb",
        "abstract_type": "Stack",
        "semantic_variant": "breadcrumb",
        "children": [
          {
            "id": "home-link",
            "abstract_type": "Trigger",
            "label": "首頁",
            "behavior_ref": "List all Semesters via GraphQL"
          },
          {
            "id": "semester-list-link",
            "abstract_type": "Trigger",
            "label": "學期列表",
            "behavior_ref": "List all Semesters via GraphQL"
          },
          {
            "id": "class-list-link",
            "abstract_type": "Trigger",
            "label": "班級管理",
            "behavior_ref": "List all Classes in a Semester via GraphQL"
          },
          {
            "id": "current-page-crumb",
            "abstract_type": "Text",
            "label": "學生名單"
          }
        ]
      },
      {
        "id": "header-section",
        "abstract_type": "Section",
        "semantic_variant": "summary-section",
        "children": [
          {
            "id": "page-title",
            "abstract_type": "Heading",
            "label": "學生管理"
          },
          {
            "id": "current-context",
            "abstract_type": "Stack",
            "children": [
              {
                "id": "semester-name",
                "abstract_type": "Text",
                "label": "學期：",
                "data_ref": "getSemesterById"
              },
              {
                "id": "class-name",
                "abstract_type": "Text",
                "label": "班級：",
                "data_ref": "getClassById"
              }
            ]
          },
          {
            "id": "add-student-button",
            "abstract_type": "Trigger",
            "semantic_variant": "primary",
            "label": "新增學生",
            "behavior_ref": "Add a Student to a Class"
          },
          {
            "id": "import-students-button",
            "abstract_type": "Trigger",
            "semantic_variant": "secondary",
            "label": "批次匯入 CSV",
            "data_ref": "importStudents",
            "behavior_ref": "Import Students from CSV (happy path)"
          }
        ]
      },
      {
        "id": "filter-section",
        "abstract_type": "Section",
        "semantic_variant": "filter-bar",
        "children": [
          {
            "id": "student-search-field",
            "abstract_type": "Field",
            "semantic_variant": "search",
            "label": "搜尋座號或姓名",
            "behavior_ref": "List all Students in a Class via GraphQL"
          }
        ]
      },
      {
        "id": "list-section",
        "abstract_type": "Section",
        "semantic_variant": "list-section",
        "children": [
          {
            "id": "student-table",
            "abstract_type": "Table",
            "semantic_variant": "data-table",
            "label": "學生資料表",
            "data_ref": "listStudents",
            "children": [
              {
                "id": "student-number-column",
                "abstract_type": "Text",
                "label": "座號"
              },
              {
                "id": "student-name-column",
                "abstract_type": "Text",
                "label": "姓名"
              },
              {
                "id": "edit-student-trigger",
                "abstract_type": "Trigger",
                "semantic_variant": "secondary",
                "label": "編輯",
                "behavior_ref": "Update Student information"
              },
              {
                "id": "delete-student-trigger",
                "abstract_type": "Trigger",
                "semantic_variant": "destructive",
                "label": "刪除",
                "behavior_ref": "Delete a Student",
                "interactions": [
                  {
                    "on_event": "on_click",
                    "target_id": "delete-student-confirm-dialog",
                    "behavior_ref": "Delete a Student"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "id": "delete-student-confirm-dialog",
        "abstract_type": "Overlay",
        "semantic_variant": "confirm-dialog",
        "label": "確認移除學生",
        "children": [
          {
            "id": "delete-student-warning-text",
            "abstract_type": "Text",
            "label": "此學生的所有成績資料將一並永久刪除，此操作無法復原。"
          },
          {
            "id": "confirm-delete-student-trigger",
            "abstract_type": "Trigger",
            "semantic_variant": "destructive",
            "label": "確認移除",
            "behavior_ref": "Delete a Student"
          },
          {
            "id": "cancel-delete-student-trigger",
            "abstract_type": "Trigger",
            "semantic_variant": "secondary",
            "label": "取消"
          }
        ]
      }
    ]
  }
}