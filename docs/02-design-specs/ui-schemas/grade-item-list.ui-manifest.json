{
  "ui_id": "grade-item-list",
  "domain_module": "CoreDomain",
  "root_element": {
    "id": "grade-item-list-page",
    "abstract_type": "Container",
    "semantic_variant": "page",
    "children": [
      {
        "id": "page-breadcrumb",
        "abstract_type": "Stack",
        "semantic_variant": "breadcrumb",
        "children": [
          {
            "id": "home-link",
            "abstract_type": "Trigger",
            "label": "首頁",
            "behavior_ref": "List all Semesters via GraphQL"
          },
          {
            "id": "semester-list-link",
            "abstract_type": "Trigger",
            "label": "學期列表",
            "behavior_ref": "List all Semesters via GraphQL"
          },
          {
            "id": "class-list-link",
            "abstract_type": "Trigger",
            "label": "班級管理",
            "behavior_ref": "List all Classes in a Semester via GraphQL"
          },
          {
            "id": "current-page-crumb",
            "abstract_type": "Text",
            "label": "成績項目"
          }
        ]
      },
      {
        "id": "header-section",
        "abstract_type": "Section",
        "semantic_variant": "summary-section",
        "children": [
          {
            "id": "page-title",
            "abstract_type": "Heading",
            "label": "成績項目管理"
          },
          {
            "id": "current-context",
            "abstract_type": "Stack",
            "children": [
              {
                "id": "semester-name",
                "abstract_type": "Text",
                "label": "學期：",
                "data_ref": "getSemesterById"
              },
              {
                "id": "class-name",
                "abstract_type": "Text",
                "label": "班級：",
                "data_ref": "getClassById"
              }
            ]
          },
          {
            "id": "create-grade-item-button",
            "abstract_type": "Trigger",
            "semantic_variant": "primary",
            "label": "建立成績項目",
            "behavior_ref": "Create a new GradeItem"
          },
          {
            "id": "manage-weights-trigger",
            "abstract_type": "Trigger",
            "semantic_variant": "secondary",
            "label": "管理權重",
            "behavior_ref": "View weight distribution summary via GraphQL"
          }
        ]
      },
      {
        "id": "filter-section",
        "abstract_type": "Section",
        "semantic_variant": "filter-bar",
        "children": [
          {
            "id": "item-type-filter",
            "abstract_type": "Selection",
            "semantic_variant": "dropdown",
            "label": "篩選類型",
            "behavior_ref": "List all GradeItems in a Class via GraphQL"
          },
          {
            "id": "item-date-filter",
            "abstract_type": "Field",
            "semantic_variant": "date",
            "label": "篩選日期",
            "behavior_ref": "List all GradeItems in a Class via GraphQL"
          }
        ]
      },
      {
        "id": "list-section",
        "abstract_type": "Section",
        "semantic_variant": "list-section",
        "children": [
          {
            "id": "grade-item-table",
            "abstract_type": "Table",
            "semantic_variant": "data-table",
            "label": "成績項目資料表",
            "data_ref": "listGradeItems",
            "children": [
              {
                "id": "item-name-column",
                "abstract_type": "Text",
                "label": "項目名稱"
              },
              {
                "id": "item-type-column",
                "abstract_type": "Text",
                "label": "類型"
              },
              {
                "id": "item-date-column",
                "abstract_type": "Text",
                "label": "日期"
              },
              {
                "id": "item-weight-column",
                "abstract_type": "Text",
                "label": "權重 (%)"
              },
              {
                "id": "edit-grade-item-trigger",
                "abstract_type": "Trigger",
                "semantic_variant": "secondary",
                "label": "編輯",
                "behavior_ref": "Update GradeItem information"
              },
              {
                "id": "delete-grade-item-trigger",
                "abstract_type": "Trigger",
                "semantic_variant": "destructive",
                "label": "刪除",
                "behavior_ref": "Delete a GradeItem",
                "interactions": [
                  {
                    "on_event": "on_click",
                    "target_id": "delete-grade-item-confirm-dialog",
                    "behavior_ref": "Delete a GradeItem"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "id": "delete-grade-item-confirm-dialog",
        "abstract_type": "Overlay",
        "semantic_variant": "confirm-dialog",
        "label": "確認刪除成績項目",
        "children": [
          {
            "id": "delete-grade-item-warning-text",
            "abstract_type": "Text",
            "label": "此項目底下所有學生的成績資料將一並永久刪除，此操作無法復原。"
          },
          {
            "id": "confirm-delete-grade-item-trigger",
            "abstract_type": "Trigger",
            "semantic_variant": "destructive",
            "label": "確認刪除",
            "behavior_ref": "Delete a GradeItem"
          },
          {
            "id": "cancel-delete-grade-item-trigger",
            "abstract_type": "Trigger",
            "semantic_variant": "secondary",
            "label": "取消"
          }
        ]
      }
    ]
  }
}