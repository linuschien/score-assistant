    active_status varchar   [note: "Computed column: CASE WHEN deleted = FALSE THEN 'ACTIVE' ELSE id END"]

    indexes {
        (semester_name, active_status) [unique]
    }
}

Table class {
    id                uuid    [pk]
    semester_id       uuid    [not null]
    class_name        varchar [not null]
    passing_threshold decimal [default: 60]
    created_at        timestamp
    updated_at        timestamp
    deleted           boolean [default: false, not null]
    deleted_at        timestamp
    active_status     varchar [note: "Computed column: CASE WHEN deleted = FALSE THEN 'ACTIVE' ELSE id END"]

    indexes {
        (semester_id, class_name, active_status) [unique]
    }
}

Table student {
    id             uuid    [pk]
    class_id       uuid    [not null]
