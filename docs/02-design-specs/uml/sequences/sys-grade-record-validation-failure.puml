@startuml sys-grade-record-validation-failure
!pragma layout smetana
skinparam backgroundColor #FFFFFF
skinparam sequence {
    ParticipantPadding 20
    MessageAlign center
}

' ── 參與者（依六角架構層次排列）──────────────────────────────────
actor "Teacher" as U
participant "GradeRecordRestControllerAdapter" as PA <<PrimaryAdapter>>
participant "GradeRecordRepositoryAdapter" as SA <<SecondaryAdapter>>

note over SA #EEEEEE
  （本場景中永不被呼叫）
  Repository NOT called — data integrity preserved.
end note

' ── 主流程 ────────────────────────────────────────────────────────
U -> PA : createGradeRecord(req: GradeRecordRequest)\n[score=-5, type=ASSIGNMENT]
activate PA

note right of PA
  契約規則：score < 0 僅允許
  CLASSROOM_PERFORMANCE 類型。
  ASSIGNMENT 觸發驗證例外。
end note

' 控制器執行自我驗證（屬於 adapter.in 層職責）
PA -> PA : createGradeRecord(req)
note over PA #FFCCCC
  ❌ 領域驗證例外拋出
  DomainValidationException
  (score out of range for type ASSIGNMENT)
end note

PA -[#red]-> U : ResponseEntity<Void>\n400 Bad Request
deactivate PA

@enduml
