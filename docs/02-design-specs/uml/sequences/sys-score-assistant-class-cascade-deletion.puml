@startuml sys-score-assistant-class-cascade-deletion
!pragma layout smetana
skinparam backgroundColor #FFFFFF
skinparam sequence {
    ParticipantPadding 20
    MessageAlign center
}

' ── 對應 BDD Scenario: Cascade deletion from Class removes all dependent entities
' ── 契約來源: class_contract.puml, student_contract.puml,
'             grade_item_contract.puml, grade_record_contract.puml,
'             attachment_contract.puml ──────────────────────────────────────────

participant "ClassRepositoryAdapter" as CRA <<SecondaryAdapter>>
participant "StudentRepositoryAdapter" as STRA <<SecondaryAdapter>>
participant "GradeItemRepositoryAdapter" as GIRA <<SecondaryAdapter>>
participant "GradeRecordRepositoryAdapter" as GRRA <<SecondaryAdapter>>
participant "AttachmentRepositoryAdapter" as ARA <<SecondaryAdapter>>
database "H2 Database" as DB

note over CRA
  觸發來源：ClassRestController.deleteClass(id)
  呼叫 ClassRepository.deleteById(id)
end note

[-> CRA : deleteById(id: UUID)
activate CRA

CRA -> DB : DELETE FROM classes WHERE id = ?
activate DB
DB --> CRA : success (DB CASCADE triggers)
deactivate DB

group Cascade Deletion: Class → Student + GradeItem → GradeRecord → Attachment

    CRA -> STRA : deleteById(studentId: UUID)\n[for each Student in Class]
    activate STRA
    STRA -> DB : DELETE FROM students WHERE id = ?
    activate DB
    DB --> STRA : success
    deactivate DB
    STRA --> CRA : void
    deactivate STRA

    CRA -> GIRA : deleteById(gradeItemId: UUID)\n[for each GradeItem in Class]
    activate GIRA
    GIRA -> DB : DELETE FROM grade_items WHERE id = ?
    activate DB
    DB --> GIRA : success
    deactivate DB

    GIRA -> GRRA : deleteById(gradeRecordId: UUID)\n[for each GradeRecord of Student+GradeItem]
    activate GRRA
    GRRA -> DB : DELETE FROM grade_records WHERE id = ?
    activate DB
    DB --> GRRA : success
    deactivate DB

    GRRA -> ARA : deleteById(attachmentId: UUID)\n[for each Attachment in GradeRecord]
    activate ARA
    ARA -> DB : DELETE FROM attachments WHERE id = ?
    activate DB
    DB --> ARA : success
    deactivate DB
    ARA --> GRRA : void
    deactivate ARA

    GRRA --> GIRA : void
    deactivate GRRA

    GIRA --> CRA : void
    deactivate GIRA

end

[<-- CRA : void
deactivate CRA

@enduml
