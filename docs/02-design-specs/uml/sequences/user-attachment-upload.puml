@startuml user-attachment-upload
!pragma layout smetana
skinparam backgroundColor #FFFFFF
skinparam sequence {
    ParticipantPadding 20
    MessageAlign center
}

actor "Teacher" as U
participant "AttachmentRestControllerAdapter" as PA <<PrimaryAdapter>>
participant "AttachmentRepositoryAdapter" as SA <<SecondaryAdapter>>
database "H2 Database" as DB

U -> PA : POST /.../attachments (AttachmentRequest + File)
activate PA

note right of PA
  Check file size (max 10MB)
  Check total attachments per record (max 5)
end note

PA -> SA : save(entity: Attachment)
activate SA

SA -> DB : INSERT INTO attachments (BLOB)
activate DB
DB --> SA : row persisted
deactivate DB

SA --> PA : Attachment
deactivate SA

PA --> U : 201 Created (AttachmentResponse)
deactivate PA

@enduml
