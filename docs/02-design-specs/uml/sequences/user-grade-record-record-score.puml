@startuml user-grade-record-record-score
!pragma layout smetana
skinparam backgroundColor #FFFFFF
skinparam sequence {
    ParticipantPadding 20
    MessageAlign center
}

actor "Teacher" as U
participant "GradeRecordRestControllerAdapter" as PA <<PrimaryAdapter>>
participant "GradeRecordRepositoryAdapter" as SA <<SecondaryAdapter>>
database "H2 Database" as DB

U -> PA : POST /.../grade-records (GradeRecordRequest)
activate PA

note right of PA
  Validate score range based on GradeItem type
end note

PA -> SA : save(entity: GradeRecord)
activate SA

SA -> DB : INSERT/UPDATE grade_records
activate DB
DB --> SA : row persisted
deactivate DB

SA --> PA : GradeRecord
deactivate SA

PA --> U : 201 Created (GradeRecordResponse)
deactivate PA

@enduml
